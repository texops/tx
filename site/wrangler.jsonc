{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "texops-site",
  "compatibility_date": "2026-03-17",
  "assets": {
    "directory": "./build"
  },
  "observability": {
    "enabled": false
  },
  "routes": [
    {
      "pattern": "texops.dev",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "preview_urls": false
}
